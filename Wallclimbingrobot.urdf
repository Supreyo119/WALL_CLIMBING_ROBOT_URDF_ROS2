  <link name="link_FR">
    <inertial>
      <origin xyz="1.3878E-17 0.023324 0" rpy="0 0 0" />
      <mass value="0.39375" />
      <inertia ixx="0.00035222" ixy="-9.2853E-22" ixz="-4.4492E-21"
               iyy="0.00058248" iyz="6.9654E-21" izz="0.00035222" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
