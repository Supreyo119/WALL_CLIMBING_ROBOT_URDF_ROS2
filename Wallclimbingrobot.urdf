      <geometry>
        <mesh filename="/home/pretom/ros2_ws/src/wallclimbingrobot/meshes/link_BR.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_BR" type="continuous">
    <origin xyz="-0.26814 -0.2 -0.04" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link_BR" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="link_BL">
    <inertial>
      <origin xyz="-5.5511E-17 -0.023324 5.5511E-17" rpy="0 0 0" />
      <mass value="0.39375" />
      <inertia ixx="0.00035222" ixy="5.4144E-21" ixz="0"
