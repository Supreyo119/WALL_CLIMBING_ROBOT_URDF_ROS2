<?xml version="1.0" encoding="utf-8"?>

<robot name="wallclimbingrobot">
  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 -0.00139167053492445" rpy="0 0 0" />
      <mass value="2.24200509812134" />
      <inertia ixx="0.0249086640869241" ixy="4.01026389598321E-18" ixz="-5.31210156988019E-18"
               iyy="0.0777395584720522" iyz="6.75854069904095E-19" izz="0.100518609386422" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="/home/pretom/ros2_ws/src/wallclimbingrobot/meshes/base_link.STL" />
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="/home/pretom/ros2_ws/src/wallclimbingrobot/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="link_BR">
    <inertial>
      <origin xyz="-2.7756E-16 0.023324 1.3878E-16" rpy="0 0 0" />
      <mass value="0.39375" />
      <inertia ixx="0.00035222" ixy="7.5731E-21" ixz="-6.1531E-21"
